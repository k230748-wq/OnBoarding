# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Agency Branding
AGENCY_NAME=Your Agency Name

# OpenAI
OPENAI_API_KEY=sk-...

# ClickUp
CLICKUP_API_TOKEN=pk_...
